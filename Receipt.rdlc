<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
	<AutoRefresh>0</AutoRefresh>
	<DataSources>
		<DataSource Name="ItemsDataSet">
			<ConnectionProperties>
				<DataProvider>System.Data.DataSet</DataProvider>
				<ConnectString>/* Local Connection */</ConnectString>
			</ConnectionProperties>
		</DataSource>
	</DataSources>
	<DataSets>
		<DataSet Name="ItemsDataSet">
			<Query>
				<DataSourceName>ItemsDataSet</DataSourceName>
				<CommandText>/* Local Query */</CommandText>
			</Query>
			<Fields>
				<Field Name="ItemPrice">
					<DataField>ItemPrice</DataField>
					<rd:TypeName>System.Decimal</rd:TypeName>
				</Field>
				<Field Name="ProdName">
					<DataField>ProdName</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="Quantity">
					<DataField>Quantity</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="SubTotal">
					<DataField>SubTotal</DataField>
					<rd:TypeName>System.Decimal</rd:TypeName>
				</Field>
			</Fields>
		</DataSet>
	</DataSets>
	<ReportParameters>
		<ReportParameter Name="TransactionId">
			<DataType>Integer</DataType>
			<DefaultValue>
				<Values>
					<Value>0</Value>
				</Values>
			</DefaultValue>
			<Prompt>Transaction ID</Prompt>
		</ReportParameter>
		<ReportParameter Name="CashierName">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>N/A</Value>
				</Values>
			</DefaultValue>
			<Prompt>Cashier Name</Prompt>
		</ReportParameter>
		<ReportParameter Name="TransactionDate">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>N/A</Value>
				</Values>
			</DefaultValue>
			<Prompt>Transaction Date</Prompt>
		</ReportParameter>
		<ReportParameter Name="TotalAmount">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>0</Value>
				</Values>
			</DefaultValue>
			<Prompt>Total Amount</Prompt>
		</ReportParameter>
		<ReportParameter Name="Tendered">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>0</Value>
				</Values>
			</DefaultValue>
			<Prompt>Tendered</Prompt>
		</ReportParameter>
		<ReportParameter Name="ChangeAmount">
			<DataType>String</DataType>
			<DefaultValue>
				<Values>
					<Value>0</Value>
				</Values>
			</DefaultValue>
			<Prompt>Change Amount</Prompt>
		</ReportParameter>
	</ReportParameters>
	<Body>
		<ReportItems>
			<Textbox Name="txtTitle">
				<CanGrow>true</CanGrow>
				<KeepTogether>true</KeepTogether>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>StarBuko Official Receipt</Value>
								<Style>
									<FontSize>14pt</FontSize>
									<FontWeight>Bold</FontWeight>
								</Style>
							</TextRun>
						</TextRuns>
						<Style>
							<TextAlign>Center</TextAlign>
						</Style>
					</Paragraph>
				</Paragraphs>
				<Top>0cm</Top>
				<Left>0cm</Left>
				<Height>0.8cm</Height>
				<Width>8.5cm</Width>
				<Style>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
			</Textbox>
			<Textbox Name="txtTransactionId">
				<CanGrow>true</CanGrow>
				<KeepTogether>true</KeepTogether>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=Parameters!TransactionId.Value</Value>
								<Style/>
							</TextRun>
						</TextRuns>
						<Style/>
					</Paragraph>
				</Paragraphs>
				<Top>0.9cm</Top>
				<Left>0cm</Left>
				<Height>0.6cm</Height>
				<Width>8.5cm</Width>
				<Style>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
			</Textbox>
			<Textbox Name="txtCashier">
				<CanGrow>true</CanGrow>
				<KeepTogether>true</KeepTogether>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=Parameters!CashierName.Value</Value>
								<Style/>
							</TextRun>
						</TextRuns>
						<Style/>
					</Paragraph>
				</Paragraphs>
				<Top>1.5cm</Top>
				<Left>0cm</Left>
				<Height>0.6cm</Height>
				<Width>8.5cm</Width>
				<Style>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
			</Textbox>
			<Textbox Name="txtDate">
				<CanGrow>true</CanGrow>
				<KeepTogether>true</KeepTogether>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=Parameters!TransactionDate.Value</Value>
								<Style/>
							</TextRun>
						</TextRuns>
						<Style/>
					</Paragraph>
				</Paragraphs>
				<Top>2.1cm</Top>
				<Left>0cm</Left>
				<Height>0.6cm</Height>
				<Width>8.5cm</Width>
				<Style>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
			</Textbox>
			<Tablix Name="ItemsTable">
				<TablixBody>
					<TablixColumns>
						<TablixColumn>
							<Width>3cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>2cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>1.5cm</Width>
						</TablixColumn>
						<TablixColumn>
							<Width>2cm</Width>
						</TablixColumn>
					</TablixColumns>
					<TablixRows>
						<TablixRow>
							<Height>0.6cm</Height>
							<TablixCells>
								<TablixCell>
									<CellContents>
										<Textbox Name="hItem">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Item</Value>
															<Style>
																<FontWeight>Bold</FontWeight>
															</Style>
														</TextRun>
													</TextRuns>
													<Style/>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Color>LightGrey</Color>
													<Style>Solid</Style>
												</Border>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="hPrice">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Price</Value>
															<Style>
																<FontWeight>Bold</FontWeight>
															</Style>
														</TextRun>
													</TextRuns>
													<Style/>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Color>LightGrey</Color>
													<Style>Solid</Style>
												</Border>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="hQty">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Qty</Value>
															<Style>
																<FontWeight>Bold</FontWeight>
															</Style>
														</TextRun>
													</TextRuns>
													<Style/>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Color>LightGrey</Color>
													<Style>Solid</Style>
												</Border>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="hSub">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>Subtotal</Value>
															<Style>
																<FontWeight>Bold</FontWeight>
															</Style>
														</TextRun>
													</TextRuns>
													<Style/>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Color>LightGrey</Color>
													<Style>Solid</Style>
												</Border>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
							</TablixCells>
						</TablixRow>
						<TablixRow>
							<Height>0.6cm</Height>
							<TablixCells>
								<TablixCell>
									<CellContents>
										<Textbox Name="dProdName">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!ProdName.Value</Value>
															<Style/>
														</TextRun>
													</TextRuns>
													<Style/>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Color>LightGrey</Color>
													<Style>Solid</Style>
												</Border>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="dItemPrice">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!ItemPrice.Value</Value>
															<Style/>
														</TextRun>
													</TextRuns>
													<Style/>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Color>LightGrey</Color>
													<Style>Solid</Style>
												</Border>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="dQuantity">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!Quantity.Value</Value>
															<Style/>
														</TextRun>
													</TextRuns>
													<Style/>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Color>LightGrey</Color>
													<Style>Solid</Style>
												</Border>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="dSubTotal">
											<CanGrow>true</CanGrow>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!SubTotal.Value</Value>
															<Style/>
														</TextRun>
													</TextRuns>
													<Style/>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Color>LightGrey</Color>
													<Style>Solid</Style>
												</Border>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
							</TablixCells>
						</TablixRow>
					</TablixRows>
				</TablixBody>
				<TablixColumnHierarchy>
					<TablixMembers>
						<TablixMember/>
						<TablixMember/>
						<TablixMember/>
						<TablixMember/>
					</TablixMembers>
				</TablixColumnHierarchy>
				<TablixRowHierarchy>
					<TablixMembers>
						<TablixMember>
							<KeepWithGroup>After</KeepWithGroup>
						</TablixMember>
						<TablixMember>
							<Group Name="Details"/>
						</TablixMember>
					</TablixMembers>
				</TablixRowHierarchy>
				<DataSetName>ItemsDataSet</DataSetName>
				<Top>2.8cm</Top>
				<Left>0cm</Left>
				<Height>1.2cm</Height>
				<Width>8.5cm</Width>
				<Style>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
			</Tablix>
			<Textbox Name="txtTotal">
				<CanGrow>true</CanGrow>
				<KeepTogether>true</KeepTogether>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=Parameters!TotalAmount.Value</Value>
								<Style>
									<FontWeight>Bold</FontWeight>
								</Style>
							</TextRun>
						</TextRuns>
						<Style/>
					</Paragraph>
				</Paragraphs>
				<Top>6cm</Top>
				<Left>0cm</Left>
				<Height>0.6cm</Height>
				<Width>8.5cm</Width>
				<Style>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
			</Textbox>
			<Textbox Name="txtTendered">
				<CanGrow>true</CanGrow>
				<KeepTogether>true</KeepTogether>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=Parameters!Tendered.Value</Value>
								<Style/>
							</TextRun>
						</TextRuns>
						<Style/>
					</Paragraph>
				</Paragraphs>
				<Top>6.7cm</Top>
				<Left>0cm</Left>
				<Height>0.6cm</Height>
				<Width>8.5cm</Width>
				<Style>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
			</Textbox>
			<Textbox Name="txtChange">
				<CanGrow>true</CanGrow>
				<KeepTogether>true</KeepTogether>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=Parameters!ChangeAmount.Value</Value>
								<Style/>
							</TextRun>
						</TextRuns>
						<Style/>
					</Paragraph>
				</Paragraphs>
				<Top>7.4cm</Top>
				<Left>0cm</Left>
				<Height>0.6cm</Height>
				<Width>8.5cm</Width>
				<Style>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
			</Textbox>
			<Textbox Name="txtThankYou">
				<CanGrow>true</CanGrow>
				<KeepTogether>true</KeepTogether>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>Thank you for visiting StarBuko!</Value>
								<Style>
									<FontStyle>Italic</FontStyle>
								</Style>
							</TextRun>
						</TextRuns>
						<Style>
							<TextAlign>Center</TextAlign>
						</Style>
					</Paragraph>
				</Paragraphs>
				<Top>8.1cm</Top>
				<Left>0cm</Left>
				<Height>0.6cm</Height>
				<Width>8.5cm</Width>
				<Style>
					<Border>
						<Style>None</Style>
					</Border>
				</Style>
			</Textbox>
		</ReportItems>
		<Height>9cm</Height>
		<Style/>
	</Body>
	<Width>8.5cm</Width>
	<Page>
		<PageHeight>29.7cm</PageHeight>
		<PageWidth>21cm</PageWidth>
		<LeftMargin>2cm</LeftMargin>
		<RightMargin>2cm</RightMargin>
		<TopMargin>2cm</TopMargin>
		<BottomMargin>2cm</BottomMargin>
		<Style/>
	</Page>
	<rd:ReportUnitType>Cm</rd:ReportUnitType>
</Report>